galoy:
  bria:
    host: bria.external.flash.invalid
  dealer:
    host: flash-price-realtime
  doSpaces:
    endpoint: https://example.com
    region: dev
    bucket: dev
  ibex:
    listenerHost: ${ibex_listener_host}
  lnd1:
    dns: lnd1.external.flash.invalid
  lnd2:
    dns: lnd2.external.flash.invalid
  kratos:
    config:
      api:
        secret:
          callbackApiKey: ${kratos_callback_api_key}
  config:
    admin_accounts:
      - role: bankowner
        phone: "+16505554334"
    bria:
      hotWalletName: dev
      queueNames:
        fast: fast
      coldStorage:
        walletName: cold
        hotToColdRebalanceQueueName: dev
    ibex:
      clientId: dev-client-id
      clientSecret: dev-client-secret
      environment: sandbox
      webhook:
        uri: ${ibex_listener_host}
    exchangeRates:
      USD:
        JMD:
          bid: 150
          ask: 160
    sendgrid:
      apiKey: dev-sendgrid-api-key
    swap:
      loopOutWhenHotWalletLessThan: 0
      swapOutAmount: 0
      swapProviders: []
      lnd1loopRestEndpoint: https://localhost:8081
      lnd1loopRpcEndpoint: localhost:11010
      lnd2loopRestEndpoint: https://localhost:8082
      lnd2loopRpcEndpoint: localhost:11011
      feeAccountingEnabled: false
    cronConfig:
      rebalanceEnabled: false
      swapEnabled: false
  api:
    flashPay:
      hostname: pay.staging.flashapp.me

kratos:
  kratos:
    config:
      dsn: postgresql://kratos-pg:kratos-pg@${kratos_pg_host}/kratos-pg
      selfservice:
        flows:
          settings:
            after:
              profile:
                hooks:
                  - hook: web_hook
                    config:
                      url: http://invalid-because-we-dont-want-profile-to-be-updated
                      method: POST
                      body: base64://ZnVuY3Rpb24oY3R4KSB7CiAgICBpZGVudGl0eV9pZDogdHJ1ZSwKICAgIHNjaGVtYV9pZDogY3R4LmlkZW50aXR5LnNjaGVtYV9pZAp9Cg==
                      auth:
                        type: api_key
                        config:
                          name: Authorization
                          value: ${kratos_callback_api_key}
                          in: header
          registration:
            after:
              password:
                hooks:
                  - hook: web_hook
                    config:
                      url: http://api:4002/kratos/registration
                      method: POST
                      response:
                        parse: false
                      body: base64:
                      auth:
                        type: api_key
                        config:
                          name: Authorization
                          value: ${kratos_callback_api_key}
                          in: header
                  - hook: session

postgresql:
  enabled: false

secrets:
  create: true
  mongodbPassword: password
  mongodbRootPassword: password
  mongodbMetricsPassword: password
  mongodbReplicaSetKey: replica
  mongodbConnectionString: mongodb://testUser:password@flash-mongodb:27017/galoy
  redisPassword: password
  geetestId: dummy
  geetestSecretKey: dummy
  twilioVerifyServiceId: ${twilio_verify_service_id}
  twilioAccountSid: ${twilio_account_sid}
  twilioAuthToken: ${twilio_auth_token}
  lnd1Macaroon: ${dummy_base64_secret_value}
  lnd1Tls: ${dummy_base64_secret_value}
  lnd1LoopMacaroon: ${dummy_base64_secret_value}
  lnd1LoopTls: ${dummy_base64_secret_value}
  lnd1PubKey: ${dummy_lnd_pubkey}
  lnd2Macaroon: ${dummy_base64_secret_value}
  lnd2Tls: ${dummy_base64_secret_value}
  lnd2LoopMacaroon: ${dummy_base64_secret_value}
  lnd2LoopTls: ${dummy_base64_secret_value}
  lnd2PubKey: ${dummy_lnd_pubkey}
  briaApiKey: bria_dev_000000000000000000000
  svixSecretKey: dummy
  proxyCheckApiKey: dummy
  doSpacesAccessKey: dummy
  doSpacesSecretKey: dummy

loop:
  enabled: false

price:
  realtime:
    config:
      quotes:
        - code: USD
          symbol: "$"
          name: US Dollar
          flag: US
      exchanges:
        - name: kraken
          enabled: true
          quoteAlias: USD
          base: BTC
          quote: USD
          provider: ccxt
          cron: "*/15 * * * * *"
        - name: bitstamp
          enabled: true
          quoteAlias: USD
          base: BTC
          quote: USD
          provider: ccxt
          cron: "*/15 * * * * *"
    host: flash-price-realtime
  history:
    host: flash-price-history
  postgresql:
    primary:
      persistence:
        enabled: false
  ibex:
    url: https://api-sandbox.poweredbyibex.io
    environment: sandbox
